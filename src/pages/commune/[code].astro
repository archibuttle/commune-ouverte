---
import Layout from '../../layouts/Layout.astro';
import ScoreBanner from '../../components/ScoreBanner.astro';
import MayorCard from '../../components/MayorCard.astro';
import KpiCard from '../../components/KpiCard.astro';
import Takeaway from '../../components/Takeaway.astro';
import SearchTrends from '../../components/SearchTrends.astro';
import SocialSentiment from '../../components/SocialSentiment.astro';
import EmergingSignals from '../../components/EmergingSignals.astro';
import Footer from '../../components/Footer.astro';

// Import all commune JSON files
const communeFiles = import.meta.glob('../../data/communes/*.json', { eager: true });

export function getStaticPaths() {
  const files = import.meta.glob('../../data/communes/*.json', { eager: true });
  return Object.entries(files).map(([path, data]: [string, any]) => {
    const code = path.split('/').pop()?.replace('.json', '') || '';
    return {
      params: { code },
      props: { commune: data.default || data },
    };
  });
}

const { commune } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

// KPI groups
const quotidienKeys = ['recettes_fonctionnement', 'depenses_fonctionnement', 'frais_personnel'];
const longTermeKeys = ['depenses_investissement', 'encours_dette', 'epargne_brute'];
---
<Layout title={`${commune.nom} - Commune Ouverte`} description={`Finances et bilan electoral de ${commune.nom} pour les municipales 2026.`}>
  <main class="max-w-4xl mx-auto px-4 py-8">
    <nav class="mb-6">
      <a href={baseUrl} class="text-sm text-blue-600 hover:text-blue-800">&larr; Toutes les villes</a>
    </nav>

    <!-- Score Banner -->
    <ScoreBanner
      nom={commune.nom}
      departement={commune.departement}
      population={commune.population}
      score={commune.finances.score_global}
      badge={commune.finances.badge_global}
    />

    <!-- Mayor + Verdict (merged) -->
    <div class="mt-4">
      <MayorCard
        maire={commune.maire}
        badge_global={commune.finances.badge_global}
        kpis={commune.finances.kpis}
      />
    </div>

    <!-- Takeaway -->
    <div class="mt-4">
      <Takeaway
        kpis={commune.finances.kpis}
        badge_global={commune.finances.badge_global}
        nom={commune.nom}
      />
    </div>

    <!-- Tab bar -->
    <div class="flex gap-0 mt-8 border-b border-neutral-200" id="tab-bar">
      <button data-target="finances" class="tab-btn active">Finances</button>
      <button data-target="social" class="tab-btn">Opinions en ligne</button>
    </div>

    <!-- Tab: Finances -->
    <div id="tab-finances" class="tab-panel pt-6">
      <h3 class="text-sm font-medium text-neutral-500 uppercase tracking-wide mb-3">Budget au quotidien</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        {quotidienKeys.map((key) => {
          const kpi = commune.finances.kpis[key];
          if (!kpi) return null;
          return (
            <KpiCard
              label={kpi.label}
              series={kpi.series}
              annees={kpi.annees}
              unite={kpi.unite}
              badge={kpi.badge}
              moyenne_strate={kpi.moyenne_strate}
              delta_pct={kpi.delta_pct}
            />
          );
        })}
      </div>

      <h3 class="text-sm font-medium text-neutral-500 uppercase tracking-wide mb-3">Vision long terme</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {longTermeKeys.map((key) => {
          const kpi = commune.finances.kpis[key];
          if (!kpi) return null;
          return (
            <KpiCard
              label={kpi.label}
              series={kpi.series}
              annees={kpi.annees}
              unite={kpi.unite}
              badge={kpi.badge}
              moyenne_strate={kpi.moyenne_strate}
              delta_pct={kpi.delta_pct}
            />
          );
        })}
      </div>
    </div>

    <!-- Tab: Opinions en ligne -->
    <div id="tab-social" class="tab-panel pt-6 hidden">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <SearchTrends commune={commune.code} />
        <SocialSentiment commune={commune.code} />
        <EmergingSignals commune={commune.code} />
      </div>
    </div>

    <Footer />
  </main>
</Layout>

<script>
  const tabBar = document.getElementById('tab-bar');
  const panels = {
    finances: document.getElementById('tab-finances'),
    social: document.getElementById('tab-social'),
  };

  tabBar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-target]') as HTMLElement;
    if (!btn) return;
    const target = btn.dataset.target as keyof typeof panels;

    // Update buttons
    tabBar.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
    btn.classList.add('active');

    // Update panels
    Object.entries(panels).forEach(([key, panel]) => {
      if (key === target) {
        panel?.classList.remove('hidden');
      } else {
        panel?.classList.add('hidden');
      }
    });
  });
</script>
