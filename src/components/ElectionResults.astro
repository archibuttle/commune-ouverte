---
interface Liste {
  tete: string;
  nuance: string;
  nom_liste: string;
  voix_pct: number;
}

interface Props {
  listes: Liste[];
  tour: string;
}

const { listes, tour } = Astro.props;

// Colors for the bars (cycle through Lumen accent palette)
const barColors = [
  "bg-blue-600",
  "bg-indigo-500",
  "bg-violet-500",
  "bg-rose-500",
  "bg-teal-500",
  "bg-amber-500",
  "bg-orange-500",
  "bg-neutral-500",
];
---
<div class="bg-white rounded-xl p-5 shadow-sm border border-neutral-200">
  <div class="text-xs font-medium text-neutral-500 uppercase tracking-wide mb-4">
    R&eacute;sultats {tour}
  </div>

  <div class="space-y-3">
    {listes.map((liste, i) => (
      <div>
        <div class="flex justify-between items-baseline mb-1">
          <div class="text-sm font-medium text-neutral-800 truncate mr-2">
            {liste.tete}
            <span class="text-neutral-400 text-xs ml-1">({liste.nuance})</span>
          </div>
          <div class="text-sm font-mono font-bold text-neutral-900 shrink-0">{liste.voix_pct.toFixed(1)}%</div>
        </div>
        <div class="w-full h-3 bg-neutral-100 rounded-full">
          <div
            class={`h-3 rounded-full ${barColors[i % barColors.length]}`}
            style={`width: ${liste.voix_pct}%`}
          ></div>
        </div>
        {liste.nom_liste && (
          <div class="text-xs text-neutral-400 mt-0.5 truncate">{liste.nom_liste}</div>
        )}
      </div>
    ))}
  </div>
</div>
