---
interface Props {
  nom: string;
  departement: string;
  population: number;
  score: number;
  badge: string;
}

const { nom, departement, population, score, badge } = Astro.props;

const badgeColors: Record<string, string> = {
  "BON": "bg-emerald-50 text-emerald-900 border-emerald-500",
  "CORRECT": "bg-teal-50 text-teal-900 border-teal-500",
  "MOYEN": "bg-amber-50 text-amber-900 border-amber-500",
  "FAIBLE": "bg-orange-50 text-orange-900 border-orange-500",
  "CRITIQUE": "bg-red-50 text-red-900 border-red-500",
};

const barColors: Record<string, string> = {
  "BON": "bg-emerald-500",
  "CORRECT": "bg-teal-500",
  "MOYEN": "bg-amber-500",
  "FAIBLE": "bg-orange-500",
  "CRITIQUE": "bg-red-500",
};

const colorClass = badgeColors[badge] || badgeColors["MOYEN"];
const barColor = barColors[badge] || barColors["MOYEN"];
const popFormatted = population.toLocaleString("fr-FR");
---
<div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-neutral-900">{nom}</h1>
      <p class="text-neutral-500 mt-1">{departement} &middot; {popFormatted} habitants</p>
    </div>
    <div class="text-right">
      <div class="text-sm text-neutral-500 mb-1">Score financier</div>
      <div class="flex items-center gap-3 justify-end">
        <span class="text-3xl font-mono font-bold text-neutral-900">{score}</span>
        <span class={`text-xs font-semibold px-2 py-1 rounded border ${colorClass}`}>{badge}</span>
      </div>
      <div class="w-32 h-2 bg-neutral-200 rounded-full mt-2 ml-auto">
        <div class={`h-2 rounded-full ${barColor}`} style={`width: ${score}%`}></div>
      </div>
    </div>
  </div>
</div>
